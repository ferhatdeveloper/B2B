# PostgREST ortam degiskenleri
# Kopyala:
#   cp config/postgrest.env.example .env.postgrest

PGRST_DB_URI=postgres://postgres:postgres@127.0.0.1:5432/b2b_local
PGRST_DB_ANON_ROLE=anon
PGRST_DB_SCHEMAS=public,logic,b2b
PGRST_SERVER_PORT=3002
PGRST_SERVER_HOST=0.0.0.0
PGRST_SERVER_CORS_ALLOWED_ORIGINS=*

# Production'da 32+ karakterli guclu secret kullanin.
# PGRST_JWT_SECRET=change-me-to-a-long-random-secret
